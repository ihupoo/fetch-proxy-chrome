{
  "manifest_version": 3,
  "name": "Ajax Proxy Devtool",
  "description": "Toggle proxy interception for XHR/Fetch/static assets and WebSocket with custom response mocking.",
  "version": "1.0.0",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "debugger",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Ajax Proxy"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content-bridge.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "inpage-ws.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
